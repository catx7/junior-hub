// ===========================================
// LocalServices Database Schema
// ===========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ===========================================
// Enums
// ===========================================

enum UserRole {
  USER
  PROVIDER
  ADMIN
}

enum JobStatus {
  DRAFT
  OPEN
  IN_PROGRESS
  PENDING_COMPLETION
  COMPLETED
  CANCELLED
}

enum ServiceCategory {
  BABYSITTING
  HOUSE_CLEANING
  LOCAL_FOOD
  OTHER
}

enum JobType {
  SERVICE_REQUEST
  SERVICE_OFFERING
}

enum PricingType {
  FIXED
  HOURLY
  PER_LOCATION
}

enum PromotionTier {
  BASIC
  PREMIUM
  FEATURED
}

enum NotificationType {
  NEW_OFFER
  OFFER_ACCEPTED
  OFFER_REJECTED
  NEW_MESSAGE
  JOB_STATUS_CHANGED
  NEW_REVIEW
  SYSTEM
}

// ===========================================
// User Model
// ===========================================

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  firebaseUid String   @unique
  name        String
  avatar      String?
  phone       String?
  bio         String?  @db.Text
  address     String?
  latitude    Float?
  longitude   Float?
  role        UserRole @default(USER)
  isVerified  Boolean  @default(false)
  rating      Float    @default(0)
  reviewCount Int      @default(0)
  locale      String   @default("en")
  fcmToken    String?  // Firebase Cloud Messaging token for push notifications
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  jobsPosted           Job[]                     @relation("JobPoster")
  jobsAccepted         Job[]                     @relation("JobProvider")
  offers               Offer[]
  reviewsGiven         Review[]                  @relation("ReviewAuthor")
  reviewsReceived      Review[]                  @relation("ReviewTarget")
  messagesFrom         Message[]                 @relation("MessageSender")
  conversations        ConversationParticipant[]
  promotions           Promotion[]
  notifications        Notification[]
  savedJobs            SavedJob[]
  reportsMade          Report[]                  @relation("ReportsMade")
  reportsReceived      Report[]                  @relation("ReportsReceived")
  kidsEventsOrganized  KidsEvent[]               @relation("EventOrganizer")
  eventRegistrations   EventRegistration[]
  clothesListings      ClothesItem[]             @relation("ClothesSeller")
  clothesClaimed       ClothesItem[]             @relation("ClothesClaimedBy")
  bookingRequests      BookingRequest[]           @relation("BookingClient")
  foodListings         LocalFood[]               @relation("FoodVendor")
  foodOrders           FoodOrder[]               @relation("FoodCustomer")
  verificationRequests VerificationRequest[]     @relation("VerificationUser")
  verificationsReviewed VerificationRequest[]    @relation("VerificationReviewer")

  @@index([firebaseUid])
  @@index([email])
  @@index([latitude, longitude])
  @@index([role])
  @@index([createdAt])
}

// ===========================================
// Job Model
// ===========================================

model Job {
  id          String          @id @default(cuid())
  title       String
  description String          @db.Text
  category    ServiceCategory
  jobType     JobType         @default(SERVICE_REQUEST)
  pricingType PricingType     @default(FIXED)
  budget      Decimal?        @db.Decimal(10, 2)
  currency    String          @default("USD")
  status      JobStatus       @default(DRAFT)
  location    String
  latitude    Float
  longitude   Float
  scheduledAt DateTime?
  completedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // Relations
  posterId        String
  poster          User              @relation("JobPoster", fields: [posterId], references: [id], onDelete: Cascade)
  providerId      String?
  provider        User?             @relation("JobProvider", fields: [providerId], references: [id], onDelete: SetNull)
  images          JobImage[]
  offers          Offer[]
  bookingRequests BookingRequest[]
  reviews         Review[]
  conversations   Conversation[]
  promotion       Promotion?
  savedBy         SavedJob[]
  notifications   Notification[]

  @@index([category, status])
  @@index([status])
  @@index([jobType, status])
  @@index([latitude, longitude])
  @@index([posterId])
  @@index([providerId])
  @@index([createdAt])
  @@index([budget])
}

// ===========================================
// Job Image Model
// ===========================================

model JobImage {
  id        String   @id @default(cuid())
  url       String
  publicId  String
  order     Int      @default(0)
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([jobId])
}

// ===========================================
// Offer Model
// ===========================================

model Offer {
  id         String   @id @default(cuid())
  price      Decimal  @db.Decimal(10, 2)
  message    String   @db.Text
  isAccepted Boolean  @default(false)
  isRejected Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  jobId      String
  job        Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  providerId String
  provider   User   @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([jobId, providerId])
  @@index([jobId])
  @@index([providerId])
  @@index([isAccepted])
}

// ===========================================
// Review Model
// ===========================================

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String   @db.Text
  createdAt DateTime @default(now())

  jobId    String
  job      Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  targetId String
  target   User   @relation("ReviewTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([jobId, authorId])
  @@index([targetId])
  @@index([rating])
  @@index([createdAt])
}

// ===========================================
// Conversation Model
// ===========================================

model Conversation {
  id        String   @id @default(cuid())
  jobId     String?
  job       Job?     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]

  @@index([jobId])
  @@index([updatedAt])
}

// ===========================================
// Conversation Participant Model
// ===========================================

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt     DateTime     @default(now())

  @@unique([conversationId, userId])
  @@index([userId])
}

// ===========================================
// Message Model
// ===========================================

model Message {
  id             String       @id @default(cuid())
  content        String       @db.Text
  imageUrl       String?
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@index([isRead])
}

// ===========================================
// Promotion Model
// ===========================================

model Promotion {
  id        String        @id @default(cuid())
  jobId     String        @unique
  job       Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier      PromotionTier @default(BASIC)
  price     Decimal       @db.Decimal(10, 2)
  startDate DateTime
  endDate   DateTime
  isActive  Boolean       @default(true)
  autoRenew Boolean       @default(false)
  createdAt DateTime      @default(now())

  @@index([isActive, endDate])
  @@index([tier, isActive])
  @@index([userId])
}

// ===========================================
// Notification Model
// ===========================================

model Notification {
  id        String           @id @default(cuid())
  type      String           // Changed from enum to string for flexibility
  title     String
  body      String
  data      Json             @default("{}")
  isRead    Boolean          @default(false)
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String?
  job       Job?             @relation(fields: [jobId], references: [id], onDelete: SetNull)
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([jobId])
}

// ===========================================
// Saved Job Model (Favorites)
// ===========================================

model SavedJob {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, jobId])
  @@index([userId])
}

// ===========================================
// Report Model (Trust & Safety)
// ===========================================

model Report {
  id          String       @id @default(cuid())
  reporterId  String
  reporter    User         @relation("ReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
  targetId    String
  target      User         @relation("ReportsReceived", fields: [targetId], references: [id], onDelete: Cascade)
  targetType  String       // 'USER', 'JOB', 'MESSAGE', 'REVIEW'
  targetRefId String       // ID of the reported item
  reason      String
  description String?      @db.Text
  status      ReportStatus @default(PENDING)
  resolvedAt  DateTime?
  resolvedBy  String?
  createdAt   DateTime     @default(now())

  @@index([status])
  @@index([targetId])
  @@index([createdAt])
}

enum ReportStatus {
  PENDING
  INVESTIGATING
  RESOLVED
  DISMISSED
}

// ===========================================
// Kids Events Model
// ===========================================

model KidsEvent {
  id                  String              @id @default(cuid())
  title               String
  description         String              @db.Text
  category            String
  ageRangeMin         Int
  ageRangeMax         Int
  date                DateTime
  time                String
  location            String
  latitude            Float?
  longitude           Float?
  maxParticipants     Int
  currentParticipants Int                 @default(0)
  price               Decimal             @db.Decimal(10, 2)
  image               String?
  organizerId         String
  organizer           User                @relation("EventOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)
  registrations       EventRegistration[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([date])
  @@index([category])
  @@index([organizerId])
  @@index([date, category])
}

model EventRegistration {
  id        String    @id @default(cuid())
  eventId   String
  event     KidsEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  childName String
  childAge  Int
  notes     String?   @db.Text
  createdAt DateTime  @default(now())

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

// ===========================================
// Kids Clothes Model
// ===========================================

model ClothesItem {
  id            String   @id @default(cuid())
  title         String
  description   String   @db.Text
  category      String
  size          String
  gender        String   // 'Boy', 'Girl', 'Unisex'
  condition     String   // 'Like New', 'Good', 'Fair'
  type          String   // 'Sell', 'Donate'
  price         Decimal? @db.Decimal(10, 2)
  originalPrice Decimal? @db.Decimal(10, 2)
  images        String[]
  location      String
  latitude      Float?
  longitude    Float?
  sellerId      String
  seller        User     @relation("ClothesSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  claimedById   String?
  claimedBy     User?    @relation("ClothesClaimedBy", fields: [claimedById], references: [id], onDelete: SetNull)
  status        String   @default("AVAILABLE") // 'AVAILABLE', 'CLAIMED', 'COMPLETED'
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([category, status])
  @@index([type, status])
  @@index([sellerId])
  @@index([status])
  @@index([createdAt])
}

// ===========================================
// Booking Request Model (for Service Offerings)
// ===========================================

model BookingRequest {
  id            String   @id @default(cuid())
  preferredDate DateTime
  message       String   @db.Text
  status        String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  jobId         String
  job           Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  clientId      String
  client        User     @relation("BookingClient", fields: [clientId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([jobId, clientId])
  @@index([jobId])
  @@index([clientId])
  @@index([status])
}

// ===========================================
// Local Food Model
// ===========================================

model LocalFood {
  id                String      @id @default(cuid())
  title             String
  description       String      @db.Text
  category          String
  price             Decimal     @db.Decimal(10, 2)
  images            String[]
  pickupOnly        Boolean     @default(false)
  pickupLocation    String?
  deliveryAvailable Boolean     @default(false)
  deliveryArea      String?
  location          String
  latitude          Float?
  longitude         Float?
  vendorId          String
  vendor            User        @relation("FoodVendor", fields: [vendorId], references: [id], onDelete: Cascade)
  orders            FoodOrder[]
  status            String      @default("AVAILABLE")
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([category, status])
  @@index([vendorId])
  @@index([status])
  @@index([createdAt])
}

model FoodOrder {
  id              String    @id @default(cuid())
  foodItemId      String
  foodItem        LocalFood @relation(fields: [foodItemId], references: [id], onDelete: Cascade)
  customerId      String
  customer        User      @relation("FoodCustomer", fields: [customerId], references: [id], onDelete: Cascade)
  quantity        Int
  orderType       String    // 'DELIVERY' or 'PICKUP'
  deliveryAddress String?
  pickupLocation  String?
  message         String?   @db.Text
  status          String    @default("PENDING") // PENDING, ACCEPTED, REJECTED, COMPLETED
  totalPrice      Decimal   @db.Decimal(10, 2)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([foodItemId])
  @@index([customerId])
  @@index([status])
}

// ===========================================
// Provider Verification Model
// ===========================================

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model VerificationRequest {
  id         String             @id @default(cuid())
  userId     String
  user       User               @relation("VerificationUser", fields: [userId], references: [id], onDelete: Cascade)
  status     VerificationStatus @default(PENDING)
  documents  Json               @default("{}") // {idCard: url, backgroundCheck: url, references: [urls]}
  notes      String?            @db.Text
  motivation String?            @db.Text
  idnormSessionId    String?    @unique
  idnormStatus       String?    // created, in_progress, completed, expired
  idnormResult       Json?      // Full verification result from idnorm
  submittedAt DateTime          @default(now())
  reviewedAt DateTime?
  reviewedBy String?
  reviewer   User?              @relation("VerificationReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([status])
  @@index([userId])
  @@index([submittedAt])
  @@index([idnormSessionId])
}
