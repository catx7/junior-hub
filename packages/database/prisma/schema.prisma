// ===========================================
// LocalServices Database Schema
// ===========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ===========================================
// Enums
// ===========================================

enum UserRole {
  USER
  PROVIDER
  ADMIN
}

enum JobStatus {
  DRAFT
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ServiceCategory {
  BABYSITTING
  HOUSE_CLEANING
  LOCAL_FOOD
  OTHER
}

enum PromotionTier {
  BASIC
  PREMIUM
  FEATURED
}

enum NotificationType {
  NEW_OFFER
  OFFER_ACCEPTED
  OFFER_REJECTED
  NEW_MESSAGE
  JOB_STATUS_CHANGED
  NEW_REVIEW
  SYSTEM
}

// ===========================================
// User Model
// ===========================================

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  firebaseUid String   @unique
  name        String
  avatar      String?
  phone       String?
  bio         String?  @db.Text
  address     String?
  latitude    Float?
  longitude   Float?
  role        UserRole @default(USER)
  isVerified  Boolean  @default(false)
  rating      Float    @default(0)
  reviewCount Int      @default(0)
  locale      String   @default("en")
  fcmToken    String?  // Firebase Cloud Messaging token for push notifications
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  jobsPosted       Job[]                     @relation("JobPoster")
  jobsAccepted     Job[]                     @relation("JobProvider")
  offers           Offer[]
  reviewsGiven     Review[]                  @relation("ReviewAuthor")
  reviewsReceived  Review[]                  @relation("ReviewTarget")
  messagesFrom     Message[]                 @relation("MessageSender")
  conversations    ConversationParticipant[]
  promotions       Promotion[]
  notifications    Notification[]
  savedJobs        SavedJob[]
  reportsMade      Report[]                  @relation("ReportsMade")
  reportsReceived  Report[]                  @relation("ReportsReceived")

  @@index([firebaseUid])
  @@index([email])
  @@index([latitude, longitude])
  @@index([role])
  @@index([createdAt])
}

// ===========================================
// Job Model
// ===========================================

model Job {
  id          String          @id @default(cuid())
  title       String
  description String          @db.Text
  category    ServiceCategory
  budget      Decimal         @db.Decimal(10, 2)
  currency    String          @default("USD")
  status      JobStatus       @default(DRAFT)
  location    String
  latitude    Float
  longitude   Float
  scheduledAt DateTime?
  completedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // Relations
  posterId     String
  poster       User          @relation("JobPoster", fields: [posterId], references: [id], onDelete: Cascade)
  providerId   String?
  provider     User?         @relation("JobProvider", fields: [providerId], references: [id], onDelete: SetNull)
  images       JobImage[]
  offers       Offer[]
  reviews      Review[]
  conversation Conversation?
  promotion    Promotion?
  savedBy      SavedJob[]

  @@index([category, status])
  @@index([status])
  @@index([latitude, longitude])
  @@index([posterId])
  @@index([providerId])
  @@index([createdAt])
  @@index([budget])
}

// ===========================================
// Job Image Model
// ===========================================

model JobImage {
  id        String   @id @default(cuid())
  url       String
  publicId  String
  order     Int      @default(0)
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([jobId])
}

// ===========================================
// Offer Model
// ===========================================

model Offer {
  id         String   @id @default(cuid())
  price      Decimal  @db.Decimal(10, 2)
  message    String   @db.Text
  isAccepted Boolean  @default(false)
  isRejected Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  jobId      String
  job        Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  providerId String
  provider   User   @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([jobId, providerId])
  @@index([jobId])
  @@index([providerId])
  @@index([isAccepted])
}

// ===========================================
// Review Model
// ===========================================

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String   @db.Text
  createdAt DateTime @default(now())

  jobId    String
  job      Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  targetId String
  target   User   @relation("ReviewTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([jobId, authorId])
  @@index([targetId])
  @@index([rating])
  @@index([createdAt])
}

// ===========================================
// Conversation Model
// ===========================================

model Conversation {
  id        String   @id @default(cuid())
  jobId     String   @unique
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]

  @@index([updatedAt])
}

// ===========================================
// Conversation Participant Model
// ===========================================

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt     DateTime     @default(now())

  @@unique([conversationId, userId])
  @@index([userId])
}

// ===========================================
// Message Model
// ===========================================

model Message {
  id             String       @id @default(cuid())
  content        String       @db.Text
  imageUrl       String?
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@index([isRead])
}

// ===========================================
// Promotion Model
// ===========================================

model Promotion {
  id        String        @id @default(cuid())
  jobId     String        @unique
  job       Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier      PromotionTier @default(BASIC)
  price     Decimal       @db.Decimal(10, 2)
  startDate DateTime
  endDate   DateTime
  isActive  Boolean       @default(true)
  autoRenew Boolean       @default(false)
  createdAt DateTime      @default(now())

  @@index([isActive, endDate])
  @@index([tier, isActive])
  @@index([userId])
}

// ===========================================
// Notification Model
// ===========================================

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  body      String
  data      Json             @default("{}")
  isRead    Boolean          @default(false)
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

// ===========================================
// Saved Job Model (Favorites)
// ===========================================

model SavedJob {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, jobId])
  @@index([userId])
}

// ===========================================
// Report Model (Trust & Safety)
// ===========================================

model Report {
  id          String       @id @default(cuid())
  reporterId  String
  reporter    User         @relation("ReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
  targetId    String
  target      User         @relation("ReportsReceived", fields: [targetId], references: [id], onDelete: Cascade)
  targetType  String       // 'USER', 'JOB', 'MESSAGE', 'REVIEW'
  targetRefId String       // ID of the reported item
  reason      String
  description String?      @db.Text
  status      ReportStatus @default(PENDING)
  resolvedAt  DateTime?
  resolvedBy  String?
  createdAt   DateTime     @default(now())

  @@index([status])
  @@index([targetId])
  @@index([createdAt])
}

enum ReportStatus {
  PENDING
  INVESTIGATING
  RESOLVED
  DISMISSED
}
