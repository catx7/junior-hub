# ===========================================
# JuniorHub Environment Configuration
# ===========================================
# Copy this file to .env.local and fill in your values

# ===========================================
# Database (Supabase for Phase 1)
# ===========================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/localservices"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/localservices"

# ===========================================
# Application
# ===========================================
# NODE_ENV is managed by Next.js automatically - do not set it here
# LOG_LEVEL: debug | info | warn | error (default: debug in dev, info in prod)
LOG_LEVEL="debug"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="JuniorHub"

# ===========================================
# Firebase Authentication
# ===========================================
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=""

# Firebase Admin SDK (Server-side)
FIREBASE_ADMIN_PROJECT_ID=""
FIREBASE_ADMIN_CLIENT_EMAIL=""
FIREBASE_ADMIN_PRIVATE_KEY=""

# ===========================================
# Cloudinary (Image Storage)
# ===========================================
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_UPLOAD_PRESET="juniorhub_unsigned"

# ===========================================
# Stripe (Phase 2)
# ===========================================
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ===========================================
# Redis (Optional - for caching/sessions)
# ===========================================
REDIS_URL="redis://localhost:6379"

# ===========================================
# Rate Limiting (Upstash for serverless)
# ===========================================
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# ===========================================
# Email (Phase 2 - Resend or SendGrid)
# ===========================================
# RESEND_API_KEY=""
# EMAIL_FROM="noreply@juniorhub.com"

# ===========================================
# Sentry (Error Tracking)
# ===========================================
# SENTRY_DSN=""
# SENTRY_AUTH_TOKEN=""

# ===========================================
# idnorm.com (Identity Verification)
# ===========================================
IDNORM_API_URL="https://api.idnorm.com"
IDNORM_API_ID=""
IDNORM_API_SECRET=""
IDNORM_CONFIG_ID=""
IDNORM_WEBHOOK_SECRET=""

# ===========================================
# Google Ads (Phase 1 Monetization)
# ===========================================
NEXT_PUBLIC_GOOGLE_ADSENSE_ID=""
# AdMob IDs are in mobile app config
